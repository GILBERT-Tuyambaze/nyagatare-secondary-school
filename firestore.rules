rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function accessProfileDoc(uid) {
      return get(/databases/$(database)/documents/access_profiles/$(uid));
    }

    function isBootstrapAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email == "gilberttuyambaze00@gmail.com";
    }

    function isSuperAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/access_profiles/$(request.auth.uid))
        && accessProfileDoc(request.auth.uid).data.role == "SuperAdmin";
    }

    function currentRole() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/access_profiles/$(request.auth.uid))
          ? accessProfileDoc(request.auth.uid).data.role
          : null;
    }

    function hasRole(role) {
      return currentRole() == role;
    }

    function isStaffViewer() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/access_profiles/$(request.auth.uid))
        && accessProfileDoc(request.auth.uid).data.role in [
          "SuperAdmin",
          "Headmaster",
          "AdmissionsOfficer",
          "DOS",
          "DOD",
          "Bursar",
          "HOD",
          "Teacher",
          "ContentManager"
        ];
    }

    function isProtectedAccessProfile() {
      return resource.data.isProtected == true || resource.data.role == "SuperAdmin";
    }

    function selfProfileUpdateKeysAllowed() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        "displayName",
        "fullName",
        "department",
        "updated_at"
      ]);
    }

    function leadershipUserUpdateKeysAllowed() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        "displayName",
        "fullName",
        "department",
        "status",
        "updated_at"
      ]);
    }

    function canManageAccessProfiles() {
      return isSuperAdmin()
        || isBootstrapAdmin()
        || hasRole("Headmaster")
        || hasRole("DOS")
        || hasRole("HOD")
        || hasRole("AdmissionsOfficer");
    }

    function canInviteRole(targetRole) {
      return isBootstrapAdmin()
        || isSuperAdmin()
        || (hasRole("Headmaster") && targetRole in [
          "AdmissionsOfficer",
          "DOS",
          "DOD",
          "Bursar",
          "HOD",
          "Teacher",
          "Student",
          "StudentLeader",
          "Animator",
          "Animatress",
          "Parent",
          "ParentLeader",
          "ContentManager",
          "Applicant",
          "Guest"
        ])
        || (hasRole("AdmissionsOfficer") && targetRole in [
          "Applicant",
          "Student",
          "Guest"
        ])
        || (hasRole("DOS") && targetRole in [
          "HOD",
          "Teacher",
          "Student",
          "StudentLeader",
          "Applicant",
          "Guest"
        ])
        || (hasRole("DOD") && targetRole in [
          "Student",
          "StudentLeader",
          "Animator",
          "Animatress",
          "ParentLeader",
          "Parent",
          "Applicant",
          "Guest"
        ])
        || (hasRole("Bursar") && targetRole in [
          "Applicant",
          "Guest"
        ])
        || (hasRole("HOD") && targetRole in [
          "Teacher",
          "Student",
          "StudentLeader",
          "Applicant",
          "Guest"
        ])
        || (hasRole("Teacher") && targetRole in [
          "Student",
          "StudentLeader",
          "Applicant"
        ])
        || (hasRole("StudentLeader") && targetRole in ["Student"])
        || (hasRole("Animator") && targetRole in ["Student"])
        || (hasRole("Animatress") && targetRole in ["Student"])
        || (hasRole("ParentLeader") && targetRole in ["Parent"])
        || (hasRole("ContentManager") && targetRole in ["Applicant", "Guest"]);
    }

    function inviteDoc(token) {
      return get(/databases/$(database)/documents/invites/$(token));
    }

    function hasValidInviteToken(token) {
      return exists(/databases/$(database)/documents/invites/$(token))
        && inviteDoc(token).data.status == "pending";
    }

    match /access_profiles/{userId} {
      allow read: if isSignedIn()
        && (
          request.auth.uid == userId
          || isSuperAdmin()
          || isBootstrapAdmin()
          || (!isProtectedAccessProfile() && isStaffViewer())
        );
      allow create: if isSuperAdmin()
        || isBootstrapAdmin()
        || (
          isSignedIn()
          && request.auth.uid == userId
          && request.resource.data.inviteToken is string
          && hasValidInviteToken(request.resource.data.inviteToken)
          && request.auth.token.email != null
          && request.resource.data.email == request.auth.token.email
          && inviteDoc(request.resource.data.inviteToken).data.email == request.auth.token.email
          && request.resource.data.role == inviteDoc(request.resource.data.inviteToken).data.role
        );
      allow update: if (
          isSignedIn()
          && request.auth.uid == userId
          && (
            ((isSuperAdmin() || isBootstrapAdmin()) && isProtectedAccessProfile())
            || (
              selfProfileUpdateKeysAllowed()
              && request.resource.data.role == resource.data.role
              && request.resource.data.email == resource.data.email
              && request.resource.data.permissions == resource.data.permissions
              && request.resource.data.isGhost == resource.data.isGhost
              && request.resource.data.isProtected == resource.data.isProtected
            )
          )
        )
        || (
          canManageAccessProfiles()
          && !isProtectedAccessProfile()
        )
        || (
          canManageAccessProfiles()
          && !isProtectedAccessProfile()
          && leadershipUserUpdateKeysAllowed()
          && request.resource.data.role == resource.data.role
          && request.resource.data.email == resource.data.email
          && request.resource.data.permissions == resource.data.permissions
          && request.resource.data.isGhost == resource.data.isGhost
          && request.resource.data.isProtected == resource.data.isProtected
        );
      allow delete: if !isProtectedAccessProfile()
        && canManageAccessProfiles();
    }

    match /students/{studentId} {
      allow read: if isStaffViewer() || isSuperAdmin() || isBootstrapAdmin();
      allow create, update, delete: if isSuperAdmin() || isBootstrapAdmin();
    }

    match /applications/{applicationId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isSuperAdmin() || isStaffViewer() || isBootstrapAdmin();
    }

    match /system_settings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin()
        || isBootstrapAdmin()
        || hasRole("Headmaster")
        || hasRole("AdmissionsOfficer")
        || hasRole("DOS")
        || hasRole("HOD");
    }

    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin() || isStaffViewer() || isBootstrapAdmin();
    }

    match /content_posts/{postId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin() || isStaffViewer() || isBootstrapAdmin();
    }

    match /donations/{donationId} {
      allow read: if isSuperAdmin() || isStaffViewer() || isBootstrapAdmin();
      allow create: if true;
      allow update, delete: if isSuperAdmin()
        || isBootstrapAdmin()
        || hasRole("Headmaster")
        || hasRole("Bursar");
    }

    match /newsletter_subscribers/{subscriberId} {
      allow read: if isSuperAdmin() || isStaffViewer() || isBootstrapAdmin();
      allow create: if true;
      allow update, delete: if isSuperAdmin()
        || isBootstrapAdmin()
        || hasRole("Headmaster")
        || hasRole("ContentManager")
        || hasRole("DOS")
        || hasRole("DOD")
        || hasRole("HOD");
    }

    match /board_members/{memberId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin() || isStaffViewer() || isBootstrapAdmin();
    }

    match /invites/{inviteId} {
      allow get: if resource.data.status == "pending"
        || isStaffViewer()
        || isSuperAdmin()
        || isBootstrapAdmin()
        || (isSignedIn() && resource.data.invitedByUid == request.auth.uid);
      allow list: if isStaffViewer()
        || isSuperAdmin()
        || isBootstrapAdmin()
        || (isSignedIn() && resource.data.invitedByUid == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.email is string
        && request.resource.data.role is string
        && request.resource.data.invitedBy is string
        && request.resource.data.invitedByUid is string
        && request.resource.data.invitedByRole is string
        && request.resource.data.status == "pending"
        && request.resource.data.invitedByUid == request.auth.uid
        && (isBootstrapAdmin() || request.resource.data.invitedByRole == currentRole())
        && canInviteRole(request.resource.data.role);
      allow create: if !isSignedIn()
        && request.resource.data.email is string
        && request.resource.data.role == "Applicant"
        && request.resource.data.invitedBy == "Admissions Portal"
        && request.resource.data.invitedByUid == "public-application"
        && request.resource.data.invitedByRole == "Applicant"
        && request.resource.data.status == "pending"
        && request.resource.data.applicationId is string;
      allow update: if isSuperAdmin()
        || isBootstrapAdmin()
        || (
          isSignedIn()
          && request.auth.token.email != null
          && request.auth.token.email == resource.data.email
          && resource.data.status == "pending"
          && request.resource.data.status == "accepted"
          && request.resource.data.acceptedByUid == request.auth.uid
          && request.resource.data.email == resource.data.email
          && request.resource.data.role == resource.data.role
          && request.resource.data.invitedByUid == resource.data.invitedByUid
          && request.resource.data.invitedByRole == resource.data.invitedByRole
        )
        || (
          isSignedIn()
          && resource.data.status == "pending"
          && resource.data.invitedByUid == request.auth.uid
          && request.resource.data.email == resource.data.email
          && request.resource.data.invitedBy == resource.data.invitedBy
          && request.resource.data.invitedByUid == resource.data.invitedByUid
          && request.resource.data.invitedByRole == resource.data.invitedByRole
          && request.resource.data.status == resource.data.status
          && canInviteRole(request.resource.data.role)
        );
      allow delete: if isSuperAdmin()
        || isBootstrapAdmin()
        || (isSignedIn() && resource.data.status == "pending" && resource.data.invitedByUid == request.auth.uid);
    }

    match /classes/{classId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSuperAdmin() || isBootstrapAdmin() || hasRole("Headmaster") || hasRole("DOS");
    }

    match /class_students/{membershipId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSuperAdmin() || isBootstrapAdmin() || hasRole("Headmaster") || hasRole("DOS") || hasRole("Teacher") || hasRole("HOD");
    }

    match /class_posts/{postId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSuperAdmin() || isBootstrapAdmin() || hasRole("Headmaster") || hasRole("DOS") || hasRole("Teacher") || hasRole("HOD");
    }

    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSuperAdmin() || isBootstrapAdmin() || hasRole("Headmaster") || hasRole("DOS") || hasRole("HOD");
    }

    match /class_teacher_assignments/{assignmentId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSuperAdmin() || isBootstrapAdmin() || hasRole("Headmaster") || hasRole("DOS") || hasRole("HOD");
    }

    match /learning_resources/{resourceId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSuperAdmin()
        || isBootstrapAdmin()
        || hasRole("Headmaster")
        || hasRole("DOS")
        || hasRole("HOD")
        || hasRole("Teacher");
    }

    match /student_marks/{markId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSuperAdmin()
        || isBootstrapAdmin()
        || hasRole("Headmaster")
        || hasRole("DOS")
        || hasRole("HOD")
        || hasRole("Teacher");
    }

    match /mark_comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin()
        || isBootstrapAdmin()
        || hasRole("Headmaster")
        || hasRole("DOS")
        || hasRole("HOD")
        || hasRole("Teacher");
    }

    match /chat_threads/{threadId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /chat_messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin() || isBootstrapAdmin();
    }

    match /discipline_cases/{caseId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSuperAdmin()
        || isBootstrapAdmin()
        || hasRole("Headmaster")
        || hasRole("DOS")
        || hasRole("DOD")
        || hasRole("HOD")
        || hasRole("Teacher");
    }

    match /activity_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin() || isBootstrapAdmin();
    }
  }
}
