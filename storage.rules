rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /application_reports/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf|image/.*|application/msword|application/vnd.openxmlformats-officedocument.wordprocessingml.document|application/vnd.ms-excel|application/vnd.openxmlformats-officedocument.spreadsheetml.sheet');
    }

    match /donation_receipts/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf|image/.*');
    }
  }
}
